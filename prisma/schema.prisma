generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── NextAuth Models ────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  email     String?
  name      String?
  password  String?
  settings  Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  accounts            Account[]
  sessions            Session[]
  platformConnections PlatformConnection[]
  personalityProfiles PersonalityProfile[]
  postHistory         PostHistory[]
  contentQueue        ContentQueue[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── App Models ─────────────────────────────────────────────

enum Platform {
  x
  linkedin
}

enum ConnectionStatus {
  active
  expired
  revoked
}

model PlatformConnection {
  id            String           @id @default(cuid())
  userId        String           @map("user_id")
  platform      Platform
  accessToken   String           @map("access_token") @db.Text
  refreshToken  String?          @map("refresh_token") @db.Text
  accountHandle String?          @map("account_handle")
  accountId     String?          @map("account_id")
  connectedAt   DateTime         @default(now()) @map("connected_at")
  tokenExpires  DateTime?        @map("token_expires")
  status        ConnectionStatus @default(active)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, platform])
  @@map("platform_connections")
}

enum PersonalityMethod {
  scrape
  quiz
  freetext
  hybrid
}

model PersonalityProfile {
  id          String            @id @default(cuid())
  userId      String            @map("user_id")
  method      PersonalityMethod
  rawInput    Json?             @map("raw_input")
  profileData Json              @map("profile_data")
  isActive    Boolean           @default(true) @map("is_active")
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("personality_profiles")
}

enum PostType {
  reply
  quote
  original
}

enum Barrel {
  barrel_1
  barrel_2
  original
}

model PostHistory {
  id             String   @id @default(cuid())
  userId         String   @map("user_id")
  platform       Platform
  postType       PostType @map("post_type")
  barrel         Barrel   @default(original)
  content        String   @db.Text
  targetPostId   String?  @map("target_post_id")
  targetAuthor   String?  @map("target_author")
  videoUrl       String?  @map("video_url")
  videoFormat    String?  @map("video_format")
  platformPostId String?  @map("platform_post_id")
  postedAt       DateTime @default(now()) @map("posted_at")
  engagement     Json     @default("{}")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, platform, postedAt])
  @@index([userId, targetAuthor])
  @@map("post_history")
}

enum QueueStatus {
  pending
  approved
  rejected
  posted
}

model ContentQueue {
  id           String      @id @default(cuid())
  userId       String      @map("user_id")
  platform     Platform
  postType     PostType    @map("post_type")
  barrel       Barrel      @default(original)
  content      String      @db.Text
  targetPostId String?     @map("target_post_id")
  targetAuthor String?     @map("target_author")
  videoUrl     String?     @map("video_url")
  status       QueueStatus @default(pending)
  createdAt    DateTime    @default(now()) @map("created_at")
  scheduledFor DateTime?   @map("scheduled_for")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@map("content_queue")
}
