generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── NextAuth Models ────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  email     String?
  name      String?
  password  String?
  settings  Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  accounts            Account[]
  sessions            Session[]
  platformConnections PlatformConnection[]
  personalityProfiles PersonalityProfile[]
  postHistory         PostHistory[]
  contentQueue        ContentQueue[]
  watchedAccounts     WatchedAccount[]
  autoReplyLogs       AutoReplyLog[]
  contentLearnings    ContentLearning[]
  followerSnapshots   FollowerSnapshot[]
  videoPosts          VideoPost[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── App Models ─────────────────────────────────────────────

enum Platform {
  x
  linkedin
}

enum ConnectionStatus {
  active
  expired
  revoked
}

model OAuthState {
  id           String   @id @default(cuid())
  state        String   @unique
  userId       String   @map("user_id")
  platform     Platform
  codeVerifier String?  @map("code_verifier")
  returnTo     String?  @map("return_to")
  expiresAt    DateTime @map("expires_at")
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("oauth_states")
}

model PlatformConnection {
  id             String           @id @default(cuid())
  userId         String           @map("user_id")
  platform       Platform
  accessToken    String           @map("access_token") @db.Text
  refreshToken   String?          @map("refresh_token") @db.Text
  twitterCookie  String?          @map("twitter_cookie") @db.Text
  accountHandle  String?          @map("account_handle")
  accountId      String?          @map("account_id")
  connectedAt    DateTime         @default(now()) @map("connected_at")
  tokenExpires   DateTime?        @map("token_expires")
  status         ConnectionStatus @default(active)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, platform])
  @@map("platform_connections")
}

enum PersonalityMethod {
  scrape
  quiz
  freetext
  hybrid
  ingest
}

model PersonalityProfile {
  id          String            @id @default(cuid())
  userId      String            @map("user_id")
  method      PersonalityMethod
  rawInput    Json?             @map("raw_input")
  profileData       Json              @map("profile_data")
  replyInstructions  String?           @map("reply_instructions") @db.Text
  feedbackExamples   Json?             @map("feedback_examples")
  isActive           Boolean           @default(true) @map("is_active")
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("personality_profiles")
}

enum PostType {
  reply
  quote
  original
}

enum Barrel {
  barrel_1
  barrel_2
  original
}

model PostHistory {
  id               String    @id @default(cuid())
  userId           String    @map("user_id")
  platform         Platform
  postType         PostType  @map("post_type")
  barrel           Barrel    @default(original)
  content          String    @db.Text
  targetPostId     String?   @map("target_post_id")
  targetAuthor     String?   @map("target_author")
  targetPostContent String?  @map("target_post_content") @db.Text
  videoUrl         String?   @map("video_url")
  videoFormat      String?   @map("video_format")
  platformPostId   String?   @map("platform_post_id")
  postedAt         DateTime  @default(now()) @map("posted_at")
  engagement       Json      @default("{}")
  metricsUpdatedAt DateTime? @map("metrics_updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, platform, postedAt])
  @@index([userId, targetAuthor])
  @@map("post_history")
}

enum QueueStatus {
  pending
  approved
  rejected
  posted
}

model ContentQueue {
  id           String      @id @default(cuid())
  userId       String      @map("user_id")
  platform     Platform
  postType     PostType    @map("post_type")
  barrel       Barrel      @default(original)
  content      String      @db.Text
  targetPostId String?     @map("target_post_id")
  targetAuthor String?     @map("target_author")
  videoUrl     String?     @map("video_url")
  status       QueueStatus @default(pending)
  createdAt    DateTime    @default(now()) @map("created_at")
  scheduledFor DateTime?   @map("scheduled_for")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@map("content_queue")
}

model WatchedAccount {
  id                 String   @id @default(cuid())
  userId             String   @map("user_id")
  platform           Platform
  accountHandle      String   @map("account_handle")
  accountId          String?  @map("account_id")
  followersCount     Int?     @map("followers_count")
  isRecommended      Boolean  @default(false) @map("is_recommended")
  isEnabled          Boolean  @default(false) @map("is_enabled")
  replyCount         Int      @default(0) @map("reply_count")
  replyMode          String   @default("manual") @map("reply_mode")
  replyType          String   @default("text") @map("reply_type")
  lastCheckedTweetId String?  @map("last_checked_tweet_id")
  category           String?
  createdAt          DateTime @default(now()) @map("created_at")

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  autoReplyLogs AutoReplyLog[]

  @@unique([userId, platform, accountHandle])
  @@map("watched_accounts")
}

model ContentLearning {
  id            String   @id @default(cuid())
  userId        String   @map("user_id")
  date          DateTime @db.Date
  platform      Platform
  insights      Json
  rawAnalysis   String   @map("raw_analysis") @db.Text
  postsAnalyzed Int      @default(0) @map("posts_analyzed")
  createdAt     DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, platform, date])
  @@index([userId, platform, date])
  @@map("content_learnings")
}

model FollowerSnapshot {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  platform    Platform
  followers   Int
  capturedAt  DateTime @default(now()) @map("captured_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, platform, capturedAt])
  @@map("follower_snapshots")
}

model AutoReplyLog {
  id               String    @id @default(cuid())
  userId           String    @map("user_id")
  watchedAccountId String    @map("watched_account_id")
  targetTweetId    String    @map("target_tweet_id")
  targetTweetText  String    @map("target_tweet_text") @db.Text
  targetAuthor     String    @map("target_author")
  replyContent     String    @map("reply_content") @db.Text
  replyType        String    @default("text") @map("reply_type")
  replyTweetId        String?   @map("reply_tweet_id")
  videoUrl            String?   @map("video_url")
  movieRootId         String?   @map("movie_root_id")
  apifyRunId          String?   @map("apify_run_id")
  status              String    @default("pending")
  errorMessage        String?   @map("error_message") @db.Text
  generationStartedAt DateTime? @map("generation_started_at")
  createdAt           DateTime  @default(now()) @map("created_at")
  postedAt            DateTime? @map("posted_at")

  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  watchedAccount WatchedAccount @relation(fields: [watchedAccountId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("auto_reply_logs")
}

model VideoPost {
  id                  String    @id @default(cuid())
  userId              String    @map("user_id")
  tweetText           String    @map("tweet_text") @db.Text
  videoPrompt         String    @map("video_prompt") @db.Text
  movieRootId         String?   @map("movie_root_id")
  videoUrl            String?   @map("video_url")
  apifyRunId          String?   @map("apify_run_id")
  platformPostId      String?   @map("platform_post_id")
  status              String    @default("pending")
  errorMessage        String?   @map("error_message") @db.Text
  generationStartedAt DateTime? @map("generation_started_at")
  createdAt           DateTime  @default(now()) @map("created_at")
  postedAt            DateTime? @map("posted_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@map("video_posts")
}
